# Better Auth
# Local dev: BETTER_AUTH_URL=http://localhost:3000
# Production: BETTER_AUTH_URL=https://usecaselab.org
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# OAuth providers (configure at least one)
# Each provider OAuth app has ONE callback URL, so you need separate apps for dev vs prod.
# Local dev callback:  http://localhost:3000/api/auth/callback/<provider>
# Production callback: https://usecaselab.org/api/auth/callback/<provider>

# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# X (Twitter): https://developer.x.com/en/portal/dashboard → OAuth 2.0 settings (NOT 1.0a)
# Required scopes (Better Auth handles automatically): tweet.read, users.read, offline.access
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Local DB file (use a Coolify volume in prod, e.g. /data/explorer.db)
DB_PATH=./data/explorer.db

# Comma-separated emails that can access /admin (approve/reject submissions)
ADMIN_EMAILS=

# Server port (Express); Vite dev runs on 3000 and proxies /api to this port
PORT=3001

# Existing
GEMINI_API_KEY=
