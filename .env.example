# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# OAuth providers (configure at least one)
# Google: https://console.cloud.google.com/apis/credentials → Authorized redirect URI = ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers → Authorization callback URL = ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# X (Twitter): https://developer.x.com/en/portal/dashboard → OAuth 2.0 → Callback URL = ${BETTER_AUTH_URL}/api/auth/callback/twitter
# Required scopes (Better Auth handles automatically): tweet.read, users.read, offline.access
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Local DB file (use a Coolify volume in prod, e.g. /data/explorer.db)
DB_PATH=./data/explorer.db

# Server port (Express); Vite dev runs on 3000 and proxies /api to this port
PORT=3001

# Existing
GEMINI_API_KEY=
